@{
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body>
    <h1>Welcome to the Home Page</h1>

    <p><strong>Username:</strong> @ViewData["Username"]</p>
    <p><strong>Email:</strong> @ViewData["Email"]</p>


    <!-- Profil düğmesi -->
    <button 
        onclick="location.href='@Url.Action("RedirectToProfile", "Home")'"
        class="profile-button">
        <img src="/images/default-profile.png" alt="Profile" style="border-radius:50%; width:50px; height:50px;">
    </button>
</body>
</html>
